DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database

# Optional pool tuning
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
LOG_LEVEL=INFO

# Optional scheduler execution controls
SCHEDULER_MAX_CONCURRENT_RUNS=4
SCHEDULER_WATCHDOG_INTERVAL=5
SCHEDULER_SCHEDULE_INTERVAL=20
SCHEDULER_PYTHON_BIN=python3
SCHEDULER_WORKSPACE_ROOT=

# Optional alerting (default disabled)
# mode:
# - dingtalk_user: enterprise internal robot private message to userIds (recommended)
# - webhook: post to webhook URL
SCHEDULER_ALERT_ENABLED=0
SCHEDULER_ALERT_MODE=dingtalk_user
SCHEDULER_ALERT_USER_IDS=
SCHEDULER_ALERT_WEBHOOK=
SCHEDULER_ALERT_DEDUP_SECS=120
SCHEDULER_ALERT_TIMEOUT_SEC=5
