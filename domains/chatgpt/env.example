# DingTalk app credentials
DING_CLIENT_ID=your_client_id
DING_CLIENT_SECRET=your_client_secret
DING_ROBOT_CODE=your_robot_code
# Optional: DingTalk tech user IDs (comma/space separated) for error notifications
DING_TECH_USER_IDS=userid1,userid2
# Optional: stream websocket keepalive tuning (seconds)
DING_STREAM_WS_PING_INTERVAL=30
DING_STREAM_WS_PING_TIMEOUT=120
# Optional: de-dup window (seconds) for error notifications, set 0 to disable
DING_ERROR_NOTIFY_DEDUP_SECS=60

# LingXing token service (optional, for OpenAPI access_token)
TOKEN_URL=http://121.41.4.126:3721/token
TOKEN_REQUEST_KEY=ak_xxxxx

# Optional: Playwright CDP url
CDP_URL=http://localhost:9222
# Optional: Chrome user data directory used when auto-starting debug browser
CHROME_USER_DATA_DIR=/home/kerden/Projects/Common/web/chrome-user-data
# Required: full URL to a specific ChatGPT page (e.g. custom GPT or conversation)
GPT_URL=https://chatgpt.com

# Database settings (used by synchronize_data.Settings)
# Example keys: host, port, user, password, db
# DB config expected by Settings is a dict; set via environment variables as used in your Settings implementation.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=pass
DB_NAME=lingxing_db

# LingXing (同步) OpenAPI credentials
# HOST 可选，默认为 https://openapi.lingxing.com
HOST=https://openapi.lingxing.com
APP_ID=your_app_id
APP_SECRET=your_app_secret
MANUAL_ACCESS_TOKEN=

